@model BookingViewModel

@{
    ViewData["Title"] = "Booking Details";
}

<a asp-action="Seats"
   asp-controller="Seat"
   asp-route-timeSlotId="1"
   asp-route-tabSessionId=""
   class="btn btn-danger btn-md"
   id="backBtn">
    Back
</a>



@if (ViewData["Message"] != null )
{
    <div class="alert alert-danger">
       <p>@ViewData["Message"]</p>
    </div>
}


<h2>Booking Details</h2>
  
<p>Selected Seats: @string.Join(", ", Model.SelectedSeatNumbers)</p>
<p>Total cost: @(@Model.SelectedSeatNumbers.Count * 100) rs</p>


<div id="timer" class="alert alert-warning">Time remaining: <span id="countdown">05:00</span></div>

<form asp-action="ConfirmBooking" method="post">
    <input type="hidden" asp-for="TimeSlotId" />
    <input type="hidden" name="tabSessionId" id="tabSessionId" value="" />
    @foreach (var id in Model.SelectedSeatIds)
    {
        <input type="hidden" name="SelectedSeatIds" value="@id" />
    }

    <div class="form-group">
        <label asp-for="Name"></label>
        <input asp-for="Name" class="form-control" required />
    </div>

    <div class="form-group">
        <label asp-for="Email"></label>
        <input asp-for="Email" class="form-control" required />
    </div>


    <div class="form-group">
        <label asp-for="Password"></label>
        <input asp-for="Password" class="form-control" type="password" required />
    </div>

    <div class="form-group">
        <label asp-for="Mobile"></label>
        <input asp-for="Mobile" class="form-control" required />
    </div>

    <button type="submit" class="btn btn-success">Confirm Booking</button>
</form>

@section Scripts {
    <script>
        let timeLeft = 300;
        const countdownEl = document.getElementById("countdown");

        function updateTimer() {
            const minutes = Math.floor(timeLeft / 60);
            const seconds = timeLeft % 60;
            countdownEl.textContent = `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            if (timeLeft <= 0) {
                window.location.href = '/'; 
            }
            timeLeft--;
        }

        setInterval(updateTimer, 1000);

         
            const tabId = sessionStorage.getItem("tabBookingSessionId");
            const backBtn = document.getElementById("backBtn");
            const baseUrl = backBtn.getAttribute("href").split('?')[0];
            backBtn.setAttribute("href", `${baseUrl}?timeSlotId=1&tabSessionId=${tabId}`);

             document.getElementById("tabSessionId").value = tabId;



    </script>
}
